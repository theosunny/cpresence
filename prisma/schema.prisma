generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  name                 String
  avatar               String?
  tier                 String   @default("starter")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  personas  Persona[]
  contents  Content[]
  leads     Lead[]
  analytics AnalyticsSnapshot[]
}

model Persona {
  id                   String   @id @default(uuid())
  userId               String
  platform             String
  tone                 String   @default("casual_professional")
  avgSentenceLength    Int      @default(18)
  usesEmoji            Boolean  @default(true)
  emojiFrequency       String   @default("moderate")
  commonPhrases        Json     @default("[]")
  commonOpenings       Json     @default("[]")
  commonClosings       Json     @default("[]")
  humorStyle           String   @default("none")
  formality            Float    @default(0.3)
  questionFrequency    Float    @default(0.2)
  hashtagStyle         String   @default("minimal")
  avgPostLength        Int      @default(500)
  expertiseTopics      Json     @default("[]")
  includesCallToAction Boolean  @default(true)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  contents Content[]

  @@unique([userId, platform])
}

model Content {
  id            String    @id @default(uuid())
  userId        String
  personaId     String
  platform      String
  action        String
  content       String    @db.Text
  aiGenerated   Boolean   @default(true)
  status        String    @default("pending_review")
  scheduledAt   DateTime
  publishedAt   DateTime?
  targetPostUrl String?
  targetUserId  String?
  retryCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  persona Persona @relation(fields: [personaId], references: [id])
}

model Lead {
  id                 String   @id @default(uuid())
  userId             String
  platform           String
  platformUsername   String
  platformAvatar     String?
  interactionType    String
  interactionContent String   @db.Text
  score              Int      @default(0)
  level              String   @default("low")
  signals            Json     @default("[]")
  isRead             Boolean  @default(false)
  isContacted        Boolean  @default(false)
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AnalyticsSnapshot {
  id             String   @id @default(uuid())
  userId         String
  platform       String
  date           DateTime
  followers      Int      @default(0)
  impressions    Int      @default(0)
  engagementRate Float    @default(0)
  clicks         Int      @default(0)
  leadsGenerated Int      @default(0)
  postsCount     Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, platform, date])
}
